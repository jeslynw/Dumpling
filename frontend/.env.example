# Copy this file to .env.local and fill in values

# Backend API base URL — points to FastAPI server
# TODO: BACKEND — Update this when your FastAPI server is running
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to "true" to use mock data without a running backend
# Set to "false" when backend is ready to connect
NEXT_PUBLIC_USE_MOCKS=true
